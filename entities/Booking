      "type": "string"
    },
    "service_title": {
      "type": "string"
    },
    "provider_email": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "time_slot": {
      "type": "string"
    },
