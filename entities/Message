{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_key": {
      "type": "string",
      "description": "Sorted sender+receiver emails as key"
    },
    "sender_email": {
      "type": "string"
    },
    "receiver_email": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "listing_id": {
      "type": "string",
      "description": "Related product or service ID"
    },
    "listing_type": {
      "type": "string",
      "enum": [
        "product",
        "service"
      ]
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "sender_name": {
      "type": "string"
    }
  },
  "required": [
    "conversation_key",
    "sender_email",
    "receiver_email",
    "content"
  ]
}
