{
  "name": "Product",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Product title"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Price in ZAR"
    },
    "category": {
      "type": "string",
      "enum": [
        "electronics",
        "clothing",
        "furniture",
        "groceries",
        "vehicles",
        "car_parts",
        "books",
        "herbs_traditional",
        "school_uniforms",
        "food_packs",
        "beauty",
        "sports",
        "home_garden",
        "phones",
        "other"
      ],
      "description": "Product category"
    },
    "condition": {
      "type": "string",
      "enum": [
        "new",
        "like_new",
        "used",
        "refurbished"
      ],
      "default": "used"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product image URLs"
    },
    "province": {
      "type": "string",
      "enum": [
        "gauteng",
        "western_cape",
        "kwazulu_natal",
        "eastern_cape",
        "free_state",
        "limpopo",
        "mpumalanga",
        "north_west",
        "northern_cape"
      ],
      "description": "Province"
    },
    "city": {
      "type": "string",
      "description": "City or township"
    },
    "is_urgent": {
      "type": "boolean",
      "default": false,
      "description": "Urgent sale tag"
    },
    "is_boosted": {
      "type": "boolean",
      "default": false,
      "description": "Boosted listing"
    },
    "is_negotiable": {
      "type": "boolean",
      "default": true,
      "description": "Price is negotiable"
    },
    "delivery_options": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "pickup",
          "local_delivery",
          "courier",
          "meet_public"
        ]
      },
      "description": "Available delivery options"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "sold",
        "reserved",
        "removed"
      ],
      "default": "active"
    },
    "views": {
      "type": "number",
      "default": 0
    },
    "seller_name": {
      "type": "string"
    },
    "seller_phone": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "price",
    "category"
  ]
}
